n class="ͼe">render</span><span>();</span><br><span>}</span><br><br><span class="ͼ8">function</span><span> </span><span class="ͼe">remove</span><span>(</span><span class="ͼe">name</span><span>){</span><br><span>    </span><span class="ͼ8">if</span><span>(</span><span class="ͼe">cart</span><span>[</span><span class="ͼe">name</span><span>]){</span><br><span>        </span><span class="ͼe">cart</span><span>[</span><span class="ͼe">name</span><span>]</span><span class="ͼ8">.</span><span>qty</span><span class="ͼ8">--</span><span>;</span><br><span>        </span><span class="ͼ8">if</span><span>(</span><span class="ͼe">cart</span><span>[</span><span class="ͼe">name</span><span>]</span><span class="ͼ8">.</span><span>qty </span><span class="ͼ8">&lt;=</span><span> </span><span class="ͼb">0</span><span>){</span><br><span>            </span><span class="ͼ8">delete</span><span> </span><span class="ͼe">cart</span><span>[</span><span class="ͼe">name</span><span>];</span><br><span>        }</span><br><span>    }</span><br><span>    </span><span class="ͼe">render</span><span>();</span><br><span>}</span><br><br><span class="ͼ8">function</span><span> </span><span class="ͼe">render</span><span>(){</span><br><span>    </span><span class="ͼ8">let</span><span> </span><span class="ͼe">html</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼc">""</span><span>;</span><br><span>    </span><span class="ͼ8">let</span><span> </span><span class="ͼe">total</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼb">0</span><span>;</span><br><br><span>    </span><span class="ͼ8">for</span><span>(</span><span class="ͼ8">let</span><span> </span><span class="ͼe">item</span><span> </span><span class="ͼ8">in</span><span> </span><span class="ͼe">cart</span><span>){</span><br><span>        </span><span class="ͼ8">let</span><span> </span><span class="ͼe">c</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">cart</span><span>[</span><span class="ͼe">item</span><span>];</span><br><span>        </span><span class="ͼ8">let</span><span> </span><span class="ͼe">sub</span><span> </span><span class="ͼ8">=</span><span> </span><span class="ͼe">c</span><span class="ͼ8">.</span><span>qty </span><span class="ͼ8">*</span><span> </span><span class="ͼe">c</span><span class="ͼ8">.</span><span>price;</span><br><span>        </span><span class="ͼe">total</span><span> </span><span class="ͼ8">+=</span><span> </span><span class="ͼe">sub</span><span>;</span><br><br><span>        </span><span class="ͼe">html</span><span> </span><span class="ͼ8">+=</span><span> </span><span class="ͼc">`</span><br><span class="ͼc">        &lt;div class="cart-item"&gt;</span><br><span class="ͼc">            </span><span>${</span><span class="ͼe">item</span><span>}</span><span class="ͼc"> x</span><span>${</span><span class="ͼe">c</span><span class="ͼ8">.</span><span>qty}</span><span class="ͼc"> → $</span><span>${</span><span class="ͼe">sub</span><span>}</span><br><span class="ͼc">            &lt;div class="cart-controls"&gt;</span><br><span class="ͼc">                &lt;button onclick="add('</span><span>${</span><span class="ͼe">item</span><span>}</span><span class="ͼc">', </span><span>${</span><span class="ͼe">c</span><span class="ͼ8">.</span><span>price}</span><span class="ͼc">)"&gt;+&lt;/button&gt;</span><br><span class="ͼc">                &lt;button onclick="remove('</span><span>${</span><span class="ͼe">item</span><span>}</span><span class="ͼc">')"&gt;-&lt;/button&gt;</span><br><span class="ͼc">            &lt;/div&gt;</span><br><span class="ͼc">        &lt;/div&gt;</span><br><span class="ͼc">        `</span><span>;</span><br><span>    }</span><br><br><span>    </span><span class="ͼe">document</span><span class="ͼ8">.</span><span>getElementById(</span><span class="ͼc">"cartItems"</span><span>)</span><span class="ͼ8">.</span><span>innerHTML </span><span class="ͼ8">=</span><span> </span><span class="ͼe">html</span><span> </span><span class="ͼ8">||</span><span> </span><span class="ͼc">"Vacío"</span><span>;</span><br><span>    </span><span class="ͼe">document</span><span class="ͼ8">.</span><span>getElementById(</span><span class="ͼc">"total"</span><span>)</span><span class="ͼ8">.</span><span>innerText </span><span class="ͼ8">=</span><span> </span><span class="ͼc">"Total: $"</span><span> </span><span class="ͼ8">+</span><span> </span><span class="ͼe">total</span><span>;</span><br><span>}</span><br><br><span class="ͼ8">function</span><span> </span><span class="ͼe">show</span><span>(</span><span class="ͼe">id</span><span>){</span><br><span>    </span><span class="ͼe">document</span><span class="ͼ8">.</span><span>querySelectorAll(</span><span class="ͼc">'.section'</span><span>)</span><span class="ͼ8">.</span><span>forEach(</span><span class="ͼe">s</span><span>=&gt;</span><span class="ͼe">s</span><span class="ͼ8">.</span><span>classList</span><span class="ͼ8">.</span><span>remove(</span><span class="ͼc">'active'</span><span>));</span><br><span>    </span><span class="ͼe">document</span><span class="ͼ8">.</span><span>getElementById(</span><span class="ͼe">id</span><span>)</span><span class="ͼ8">.</span><span>classList</span><span class="ͼ8">.</span><span>add(</span><span class="ͼc">'active'</span><span>);</span><br><span>}</span><br><br><span class="ͼg">&lt;/script&gt;</span><br><br><span class="ͼg">&lt;/body&gt;</span><br><span class="ͼg">&lt;/html&gt;</span></div></div></div></div></div></div></div></div></div><div class=""><div class="" style="width: 100%; transform: none;"></div></div></div></div></div></pre>
